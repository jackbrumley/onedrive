{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "onedrive-gui",
  "version": "0.1.0",
  "identifier": "com.onedrive.gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OneDrive GUI",
        "width": 980,
        "height": 700,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
